# TerraTrust AR — Environment Variables Template
# Copy this file to .env.development or .env.production and fill in real values
# DO NOT commit local env files — they are in .gitignore
# Firebase Android config comes from android/app/google-services.json

API_BASE_URL=
GOOGLE_MAPS_API_KEY=
# Required by src/services/blockchain.ts for direct on-chain dashboard balance reads
ALCHEMY_POLYGON_AMOY_URL=
CONTRACT_ADDRESS=
# Set to true only for frontend testing to bypass audit zone and land-location checks.
AUDIT_DEMO_MODE=false
# Set to true only for temporary testing to skip tree species detection and go straight to diameter/height measurement.
AUDIT_SKIP_SPECIES_DETECTION=false
